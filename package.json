{
  "name": "koubrowser",
  "version": "1.0.0",
  "description": "甲ブラウザ",
  "main": "./out/main/index.js",
  "private": true,
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "gen:types": "npx orval",
    "gen:licenses": "node scripts/generate-bundled-licenses.js",
    "copy-dev-code": "node scripts/copy-dev-code.js",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run gen:licenses && npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "npm run gen:licenses && npm run copy-dev-code && electron-vite dev",
    "build": "npm run copy-dev-code && npm run typecheck && electron-vite build",
    "build-silent": "npm run copy-dev-code && npm run typecheck && electron-vite build --logLevel warn",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "test": "vitest run",
    "test:hr": "vitest",
    "@test:u command comment": "Update snapshots. Run this if a snapshot test fails and the changes are expected.",
    "test:u": "vitest --update",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fortawesome/fontawesome-free": "^7.1.0",
    "buefy": "3.0.2",
    "electron-updater": "^6.3.9",
    "highcharts": "9.3.3",
    "moment": "^2.30.1",
    "nedb": "^1.8.0",
    "qs": "^6.14.0",
    "uuid": "^12.0.0",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/http-proxy": "^1.17.16",
    "@types/nedb": "^1.8.16",
    "@types/node": "^22.16.5",
    "@types/qs": "^6.14.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "electron": "^39.8.10",
    "electron-builder": "^26.8.1",
    "electron-vite": "^4.0.0",
    "eslint": "^9.31.0",
    "eslint-plugin-vue": "^10.3.0",
    "happy-dom": "^20.0.0",
    "orval": "^8.2.0",
    "prettier": "^3.6.2",
    "sass-embedded": "1.93.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.5",
    "vite-svg-loader": "^5.1.0",
    "vitest": "^3.2.4",
    "vue": "3.5.17",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.0.3"
  }
}
